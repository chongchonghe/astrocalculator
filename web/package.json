{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dump-constants": "python3 scripts/dump-constants.py",
    "dump-units": "python3 scripts/dump-units.py",
    "dump-data": "npm run dump-constants && npm run dump-units",
    "copy-calc": "cp src/engine/calculator.py public/calculator.py",
    "prebuild": "npm run dump-data && npm run copy-calc",
    "predev": "npm run dump-data && npm run copy-calc"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "pyodide": "^0.29.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0"
  }
}
